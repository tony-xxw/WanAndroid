<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.study.kotlin.wan.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_blogFragment"
            app:destination="@id/blogFragment" />
        <action
            android:id="@+id/action_homeFragment_to_sampleActivity"
            app:destination="@id/sampleActivity" />
    </fragment>
    <fragment
        android:id="@+id/blogFragment"
        android:name="com.study.kotlin.wan.BlogFragment"
        android:label="fragment_blog"
        tools:layout="@layout/fragment_blog" />
    <activity
        android:id="@+id/sampleActivity"
        android:name="com.study.kotlin.wan.SampleActivity"
        android:label="SampleActivity" />


</navigation>